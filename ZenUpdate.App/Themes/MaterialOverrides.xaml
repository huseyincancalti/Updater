<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        MaterialOverrides.xaml
        App-specific style overrides and shared converters.
        Keep one concern per section.

        Theme colours are NOT defined here. They live in:
            Themes/ZenColors.Dark.xaml
            Themes/ZenColors.Light.xaml
        ThemeService swaps one of those in at runtime. Consume them via
        DynamicResource so the UI reacts to theme changes without a restart.
    -->

    <!-- ===== Converters (required by all Views) ===== -->
    <!--
        BooleanToVisibilityConverter is built into WPF.
        We register it here as a global resource so every View can use it.
    -->
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!-- ===== Status Badge (shared across Programs, Windows Updates, Drivers) =====

         One DataTemplate covers all three pages because every update item type
         exposes the same UpdateStatus enum on its Status property.

         DataTrigger comparisons work because WPF's TypeConverter converts the
         string literal (e.g. "Installing") to the matching UpdateStatus enum value
         before comparing — no code-behind or converter needed.

         Colors come from the current Zen theme dictionary (Dark or Light), so
         badges automatically re-tint when the user switches theme.
    -->
    <DataTemplate x:Key="StatusBadgeCellTemplate">
        <Border x:Name="BadgeBorder"
                CornerRadius="5"
                Padding="8,3"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{DynamicResource ZenBadgePendingBackgroundBrush}">
            <TextBlock x:Name="BadgeText"
                       Text="{Binding Status}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenBadgePendingForegroundBrush}" />
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="Downloading">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeDownloadingBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeDownloadingForegroundBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Installing">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeInstallingBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeInstallingForegroundBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Succeeded">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeSucceededBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeSucceededForegroundBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Failed">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeFailedBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeFailedForegroundBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Blacklisted">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeBlacklistedBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeBlacklistedForegroundBrush}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===== ComboBox ===== -->
    <!--
        ZenComboBoxToggleButtonTemplate
        The toggle button IS the visible chrome of the closed ComboBox.
        It renders the rounded border + chevron icon, and reacts to hover/open states.
        The outer Border (templateRoot) carries Background/BorderBrush so the
        themed colours show — this prevents the default Windows gray from leaking.
    -->
    <ControlTemplate x:Key="ZenComboBoxToggleButtonTemplate" TargetType="ToggleButton">
        <Border x:Name="templateRoot"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8"
                SnapsToDevicePixels="true">
            <!-- Chevron sits in the right 30 px; no extra border needed -->
            <materialDesign:PackIcon x:Name="Chevron"
                                     Kind="ChevronDown"
                                     Foreground="{TemplateBinding Foreground}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Width="18" Height="18"
                                     Margin="0,0,10,0"
                                     Opacity="0.75" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="templateRoot" Property="Background"   Value="{DynamicResource ZenSidebarHoverBrush}" />
                <Setter TargetName="templateRoot" Property="BorderBrush"  Value="{DynamicResource ZenPrimaryBrush}" />
                <Setter TargetName="Chevron"      Property="Opacity"      Value="1" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="templateRoot" Property="Background"   Value="{DynamicResource ZenSidebarHoverBrush}" />
                <Setter TargetName="templateRoot" Property="BorderBrush"  Value="{DynamicResource ZenPrimaryBrush}" />
                <Setter TargetName="Chevron"      Property="Opacity"      Value="1" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!--
        ZenComboBoxStyle
        Full-replacement ComboBox template so the default WPF chrome (gray
        system-button look) never appears. All colours come from DynamicResource
        so both Dark and Light themes work without changes.
    -->
    <Style x:Key="ZenComboBoxStyle" TargetType="{x:Type ComboBox}">
        <!-- Themed surface background — eliminates the gray default -->
        <Setter Property="Foreground"                              Value="{DynamicResource ZenTextBrush}" />
        <Setter Property="Background"                              Value="{DynamicResource ZenSurfaceBrush}" />
        <Setter Property="BorderBrush"                             Value="{DynamicResource ZenGlassBorderBrush}" />
        <Setter Property="BorderThickness"                         Value="1" />
        <!-- Kill the dotted focus rectangle — our border glow handles it -->
        <Setter Property="FocusVisualStyle"                        Value="{x:Null}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto" />
        <!-- Comfortable padding: text starts 14 px in, 10 px top/bottom -->
        <Setter Property="Padding"                                 Value="14,10" />
        <Setter Property="MinHeight"                               Value="40" />
        <Setter Property="HorizontalContentAlignment"              Value="Left" />
        <Setter Property="VerticalContentAlignment"                Value="Center" />
        <Setter Property="ScrollViewer.CanContentScroll"           Value="True" />
        <Setter Property="ScrollViewer.PanningMode"                Value="Both" />
        <Setter Property="Stylus.IsFlicksEnabled"                  Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="0" /><!-- collapsed; chevron is inside toggle button -->
                        </Grid.ColumnDefinitions>

                        <!-- Drop-down popup -->
                        <Popup x:Name="PART_Popup"
                               Grid.ColumnSpan="2"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                               Margin="1"
                               PopupAnimation="Fade"
                               Placement="Bottom">
                            <Border x:Name="dropDownBorder"
                                    Background="{DynamicResource ZenDeepBackgroundBrush}"
                                    BorderBrush="{DynamicResource ZenPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="0,4"
                                    Margin="0,3,0,0"
                                    MinHeight="30"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{Binding ActualWidth, ElementName=templateRoot}">
                                <ScrollViewer x:Name="DropDownScrollViewer">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <Canvas HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0" />
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>

                        <!--
                            ToggleButton spans the whole control (Grid.ColumnSpan="2").
                            It owns the visible rounded border + chevron through
                            ZenComboBoxToggleButtonTemplate — no default chrome remains.
                        -->
                        <ToggleButton x:Name="toggleButton"
                                      Grid.ColumnSpan="2"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Foreground="{TemplateBinding Foreground}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False"
                                      Template="{StaticResource ZenComboBoxToggleButtonTemplate}" />

                        <!-- Selected-item text sits on top of the toggle button -->
                        <ContentPresenter x:Name="contentPresenter"
                                          Grid.Column="0"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          IsHitTestVisible="False"
                                          Margin="{TemplateBinding Padding}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Focused state: highlight border with accent colour -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="toggleButton" Property="BorderBrush" Value="{DynamicResource ZenPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- ComboBoxItem style: hover + selected colours from active theme -->
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type ComboBoxItem}">
                    <Setter Property="Padding"          Value="14,9" />
                    <Setter Property="Foreground"        Value="{DynamicResource ZenTextBrush}" />
                    <Setter Property="Background"        Value="Transparent" />
                    <Setter Property="BorderThickness"   Value="0" />
                    <Setter Property="FocusVisualStyle"  Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                <Border x:Name="ItemBorder"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="6"
                                        Margin="4,2">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ZenSidebarHoverBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ZenPrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected"   Value="True" />
                                            <Condition Property="IsMouseOver"  Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ZenPrimaryBrush}" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Typography ===== -->
    <Style x:Key="PageTitleStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
        <Setter Property="Margin"     Value="0,0,0,16" />
        <Setter Property="Foreground" Value="{DynamicResource ZenTextBrush}" />
    </Style>

    <!--
        ===== DataGrid premium styles =====
        Consumed via StaticResource in ProgramsView, WindowsUpdatesView, DriversView.
        All colours come from DynamicResource so both Dark and Light themes work.
    -->

    <!-- Column header: tinted strip with muted foreground for subtle visual hierarchy -->
    <Style x:Key="ZenDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader"
           BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
        <Setter Property="Background" Value="{DynamicResource ZenDataGridHeaderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ZenDataGridHeaderForegroundBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize"   Value="12" />
        <Setter Property="Padding"    Value="8,8" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Row: transparent → themed hover → accent selected -->
    <Style x:Key="ZenDataGridRowStyle" TargetType="DataGridRow"
           BasedOn="{StaticResource MaterialDesignDataGridRow}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ZenDataGridRowHoverBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource ZenPrimaryBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Cell: transparent so the row background shows through cleanly -->
    <Style x:Key="ZenDataGridCellStyle" TargetType="DataGridCell"
           BasedOn="{StaticResource MaterialDesignDataGridCell}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        Glass-lite panels: semi-transparent fill + hairline border + rounded corners.
        No Blur effect — WPF blurs are expensive; this fakes glass with alpha only.
    -->
    <Style x:Key="ZenGlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ZenGlassPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ZenGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <!--
        DataGrid outer chrome: premium glass frame around the table.
        Two-layer approach:
          1. Outer Border: rounded container with a subtle top-edge gradient tint (glass sheen)
             and a stronger drop shadow for physical depth.
          2. Inner DataGrid background (ZenDataGridSurfaceBrush): tinted/translucent surface
             so the ambient theme colour bleeds through rows subtly.
        ClipToBounds on the outer Border ensures the DataGrid is clipped to the rounded corners.
        DropShadowEffect RenderingBias=Performance: no GPU memory trade-off.
    -->
    <Style x:Key="ZenDataGridChromeStyle" TargetType="Border">
        <Setter Property="BorderBrush"      Value="{DynamicResource ZenDataGridChromeBorderBrush}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="CornerRadius"     Value="12" />
        <Setter Property="Padding"          Value="0" />
        <Setter Property="ClipToBounds"     Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background">
            <Setter.Value>
                <!--
                    Vertical gradient: top strip is slightly lighter (glass highlight),
                    remainder matches the chrome background brush.
                    This gives the container a 3D curved-surface feel without blur.
                -->
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#44FFFFFF" Offset="0" />
                    <GradientStop Color="#18FFFFFF" Offset="0.08" />
                    <GradientStop Color="#00FFFFFF" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="3"
                                  Direction="270"
                                  Color="#000000"
                                  Opacity="0.18"
                                  RenderingBias="Performance" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Settings / summary cards: restrained elevation + glass fill -->
    <Style x:Key="ZenGlassCardStyle" TargetType="materialDesign:Card">
        <Setter Property="Background" Value="{DynamicResource ZenGlassPanelBrush}" />
        <Setter Property="UniformCornerRadius" Value="14" />
    </Style>

    <!--
        ZenThemeToggleStyle
        A pill-shaped button used as the theme toggle on the Settings page.
        The icon and label update via DataTrigger on Settings.Theme so the
        current state is always visible at a glance.
        Command = ToggleThemeCommand on SettingsViewModel.
    -->
    <Style x:Key="ZenThemeToggleStyle" TargetType="Button">
        <Setter Property="Background"        Value="{DynamicResource ZenSurfaceBrush}" />
        <Setter Property="BorderBrush"       Value="{DynamicResource ZenGlassBorderBrush}" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="Foreground"        Value="{DynamicResource ZenTextBrush}" />
        <Setter Property="Padding"           Value="16,8" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="FocusVisualStyle"  Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"  Value="{DynamicResource ZenSidebarHoverBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ZenPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ZenPrimaryBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ZenPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
