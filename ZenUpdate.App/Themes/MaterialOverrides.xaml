<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        MaterialOverrides.xaml
        App-specific style overrides and shared converters.
        Keep one concern per section.

        Theme colours are NOT defined here. They live in:
            Themes/ZenColors.Dark.xaml
            Themes/ZenColors.Light.xaml
        ThemeService swaps one of those in at runtime. Consume them via
        DynamicResource so the UI reacts to theme changes without a restart.
    -->

    <!-- ===== Converters (required by all Views) ===== -->
    <!--
        BooleanToVisibilityConverter is built into WPF.
        We register it here as a global resource so every View can use it.
    -->
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!-- ===== Status Badge (shared across Programs, Windows Updates, Drivers) =====

         One DataTemplate covers all three pages because every update item type
         exposes the same UpdateStatus enum on its Status property.

         DataTrigger comparisons work because WPF's TypeConverter converts the
         string literal (e.g. "Installing") to the matching UpdateStatus enum value
         before comparing — no code-behind or converter needed.

         Colors come from the current Zen theme dictionary (Dark or Light), so
         badges automatically re-tint when the user switches theme.
    -->
    <DataTemplate x:Key="StatusBadgeCellTemplate">
        <Border x:Name="BadgeBorder"
                CornerRadius="5"
                Padding="8,3"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{DynamicResource ZenBadgePendingBackgroundBrush}">
            <TextBlock x:Name="BadgeText"
                       Text="{Binding Status}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ZenBadgePendingForegroundBrush}" />
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="Downloading">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeDownloadingBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeDownloadingForegroundBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Installing">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeInstallingBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeInstallingForegroundBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Succeeded">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeSucceededBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeSucceededForegroundBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Failed">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeFailedBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeFailedForegroundBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Blacklisted">
                <Setter TargetName="BadgeBorder" Property="Background" Value="{DynamicResource ZenBadgeBlacklistedBackgroundBrush}" />
                <Setter TargetName="BadgeText"   Property="Foreground" Value="{DynamicResource ZenBadgeBlacklistedForegroundBrush}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===== ComboBox ===== -->
    <ControlTemplate x:Key="ZenComboBoxToggleButtonTemplate" TargetType="ToggleButton">
        <Border x:Name="templateRoot"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8"
                SnapsToDevicePixels="true">
            <Border x:Name="splitBorder"
                    Width="30"
                    HorizontalAlignment="Right"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Margin="0"
                    SnapsToDevicePixels="true">
                <materialDesign:PackIcon Kind="ChevronDown" 
                                         Foreground="{TemplateBinding Foreground}" 
                                         HorizontalAlignment="Center" 
                                         VerticalAlignment="Center"
                                         Width="18" Height="18"
                                         Opacity="0.8"/>
            </Border>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="true">
                <Setter Property="Background" TargetName="templateRoot" Value="{DynamicResource ZenSidebarHoverBrush}" />
                <Setter Property="BorderBrush" TargetName="templateRoot" Value="{DynamicResource ZenPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="true">
                <Setter Property="Background" TargetName="templateRoot" Value="{DynamicResource ZenSidebarHoverBrush}" />
                <Setter Property="BorderBrush" TargetName="templateRoot" Value="{DynamicResource ZenPrimaryBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{DynamicResource ZenTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ZenGlassPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ZenGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
        <Setter Property="ScrollViewer.PanningMode" Value="Both" />
        <Setter Property="Stylus.IsFlicksEnabled" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid x:Name="templateRoot" SnapsToDevicePixels="true">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <Popup x:Name="PART_Popup"
                               Grid.ColumnSpan="2"
                               AllowsTransparency="true"
                               IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                               Margin="1"
                               PopupAnimation="Fade"
                               Placement="Bottom">
                            <!-- This is the popup background -->
                            <Border x:Name="dropDownBorder"
                                    Background="{DynamicResource ZenSurfaceBrush}"
                                    BorderBrush="{DynamicResource ZenGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,4,0,0"
                                    MinHeight="30"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{Binding ActualWidth, ElementName=templateRoot}">
                                <ScrollViewer x:Name="DropDownScrollViewer">
                                    <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">
                                        <Canvas x:Name="canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0" />
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                        <ToggleButton x:Name="toggleButton"
                                      Grid.ColumnSpan="2"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Foreground="{TemplateBinding Foreground}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Template="{StaticResource ZenComboBoxToggleButtonTemplate}" />
                        <ContentPresenter x:Name="contentPresenter"
                                          Grid.Column="0"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          IsHitTestVisible="false"
                                          Margin="{TemplateBinding Padding}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type ComboBoxItem}">
                    <Setter Property="Padding" Value="14,10" />
                    <Setter Property="Foreground" Value="{DynamicResource ZenTextBrush}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                <Border x:Name="ItemBorder"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="6"
                                        Margin="4,2">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ZenSidebarHoverBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ZenPrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Typography ===== -->
    <Style x:Key="PageTitleStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
        <Setter Property="Margin"     Value="0,0,0,16" />
        <Setter Property="Foreground" Value="{DynamicResource ZenTextBrush}" />
    </Style>

    <!--
        Glass-lite panels: semi-transparent fill + hairline border + rounded corners.
        No Blur effect — WPF blurs are expensive; this fakes glass with alpha only.
    -->
    <Style x:Key="ZenGlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ZenGlassPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ZenGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <!--
        DataGrid outer chrome: subtle frame around an opaque DataGrid. Keeps
        row/cell backgrounds solid (readability) while the container feels lifted.
    -->
    <Style x:Key="ZenDataGridChromeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ZenDataGridChromeBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ZenGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- Settings / summary cards: restrained elevation + glass fill -->
    <Style x:Key="ZenGlassCardStyle" TargetType="materialDesign:Card">
        <Setter Property="Background" Value="{DynamicResource ZenGlassPanelBrush}" />
        <Setter Property="UniformCornerRadius" Value="14" />
    </Style>

</ResourceDictionary>
