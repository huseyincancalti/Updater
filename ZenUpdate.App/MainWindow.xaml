<Window x:Class="ZenUpdate.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ZenUpdate.App.ViewModels"
        xmlns:views="clr-namespace:ZenUpdate.App.Views"
        Title="ZenUpdate"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="800"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource ZenAmbientBackgroundBrush}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" 
                      ResizeBorderThickness="6" 
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Style>
        <Style TargetType="Window">
            <Style.Triggers>
                <!-- Add slight padding when maximized so the custom chrome isn't clipped -->
                <Trigger Property="WindowState" Value="Maximized">
                    <Setter Property="Padding" Value="8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <!--
        DataContext is set in App.xaml.cs to ShellViewModel.
        No code-behind logic here except small log drawer helpers.
    -->

    <!-- DataTemplates: map page ViewModels to their Views -->
    <Window.Resources>
        <!--
            Custom Window Control Buttons (Minimize, Maximize, Close)
        -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ZenSidebarHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Shell-local styles only. All colours come from the active Zen theme
            (DynamicResource ZenSidebarBrush, ZenSidebarHoverBrush, ...) so the
            sidebar and log drawer repaint as soon as the theme is switched.
        -->

        <Style x:Key="SidebarNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="14,4" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource MaterialDesignBody}" />
            <Setter Property="TextElement.FontSize" Value="13" />
            <Setter Property="TextElement.FontWeight" Value="SemiBold" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ZenSidebarHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ZenNavItemSelectedBackgroundBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="TextElement.Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--
            Flat toggle button used as the log drawer header.
            Keeps the full bar clickable while respecting the app's dark theme.
        -->
        <Style x:Key="LogDrawerHeaderToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder"
                                        Property="Background"
                                        Value="{DynamicResource ZenLogDrawerHeaderHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type vm:ProgramsViewModel}">
            <views:ProgramsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WindowsUpdatesViewModel}">
            <views:WindowsUpdatesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DriversViewModel}">
            <views:DriversView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="40" />
            <!-- Main content area -->
            <RowDefinition Height="*" />
            <!-- Log drawer: Auto so the row only takes as much space as the drawer needs. -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Custom Title Bar ===== -->
        <Grid Grid.Row="0" Background="{DynamicResource ZenDeepBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: Icon & Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                <materialDesign:PackIcon Kind="Update" Width="18" Height="18" Foreground="{DynamicResource ZenPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="ZenUpdate" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource ZenTextBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Right: Window Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" ToolTip="Minimize">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14" />
                </Button>
                <Button Style="{StaticResource WindowControlButtonStyle}" Click="MaximizeButton_Click" ToolTip="Maximize">
                    <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14" />
                </Button>
                <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="Close">
                    <materialDesign:PackIcon Kind="WindowClose" Width="14" Height="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Main Area: Sidebar + Content ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="224" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== Left Sidebar Navigation ===== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ZenSidebarPanelBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource MaterialDesignDivider}">
                <StackPanel>

                    <!-- App logo / title -->
                    <TextBlock Text="ZenUpdate"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ZenPrimaryBrush}"
                               Margin="20,24,20,20" />

                    <Separator Margin="14,0,14,8" />

                    <!-- Navigation buttons -->
                    <!-- Navigation: Buttons support Command binding; ListBoxItem does not -->
                    <StackPanel>

                        <Button x:Name="NavPrograms"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="{x:Static vm:AppPage.Programs}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="{x:Static vm:AppPage.Programs}">
                                            <Setter Property="Background" Value="{DynamicResource ZenNavItemSelectedBackgroundBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="TextElement.Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="PackageVariant"
                                                         Width="20"
                                                         Height="20"
                                                         VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="Programs"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Button>

                        <Button x:Name="NavWindowsUpdates"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="{x:Static vm:AppPage.WindowsUpdates}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="{x:Static vm:AppPage.WindowsUpdates}">
                                            <Setter Property="Background" Value="{DynamicResource ZenNavItemSelectedBackgroundBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="TextElement.Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="MicrosoftWindows"
                                                         Width="20"
                                                         Height="20"
                                                         VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="Windows Updates"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Button>

                        <Button x:Name="NavDrivers"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="{x:Static vm:AppPage.Drivers}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="{x:Static vm:AppPage.Drivers}">
                                            <Setter Property="Background" Value="{DynamicResource ZenNavItemSelectedBackgroundBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="TextElement.Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Cpu64Bit"
                                                         Width="20"
                                                         Height="20"
                                                         VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="Drivers"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Button>

                        <Button x:Name="NavSettings"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="{x:Static vm:AppPage.Settings}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="{x:Static vm:AppPage.Settings}">
                                            <Setter Property="Background" Value="{DynamicResource ZenNavItemSelectedBackgroundBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="TextElement.Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Cog"
                                                         Width="20"
                                                         Height="20"
                                                         VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="Settings"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Button>

                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Right Content Area ===== -->
            <!-- ContentControl automatically uses the DataTemplate matching CurrentPage's type -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentPage}"
                            Margin="0" />
        </Grid>

        <!-- ===== Bottom Log Drawer (collapsible) ===== -->
        <!--
            Structure:
              - Always-visible clickable header (ToggleButton) with a chevron icon,
                'Log Console' label and an error badge.
              - Collapsible body (ListView + action buttons) shown only when IsOpen is true.
            The drawer keeps multi-select / copy / clear behavior from the previous design.
        -->
        <Border Grid.Row="2"
                Background="{DynamicResource ZenLogDrawerMatteBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header bar (clickable toggle) -->
                <Grid Grid.Row="0" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ToggleButton Grid.Column="0"
                                  IsChecked="{Binding LogConsole.IsOpen, Mode=TwoWay}"
                                  Style="{StaticResource LogDrawerHeaderToggleStyle}"
                                  ToolTip="Show or hide the log console">
                        <StackPanel Orientation="Horizontal">
                            <!-- Chevron rotates 180° when the drawer is open. -->
                            <materialDesign:PackIcon Kind="ChevronUp"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0"
                                                     RenderTransformOrigin="0.5,0.5">
                                <materialDesign:PackIcon.RenderTransform>
                                    <RotateTransform x:Name="LogChevronRotation" Angle="0" />
                                </materialDesign:PackIcon.RenderTransform>
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LogConsole.IsOpen}" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>

                            <TextBlock Text="Log Console"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Opacity="0.85" />

                            <!-- Small badge shown only while errors are present. -->
                            <Border Background="{DynamicResource ZenErrorBrush}"
                                    CornerRadius="8"
                                    Padding="6,1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding LogConsole.HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding LogConsole.ErrorCount, StringFormat={}{0} error(s)}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="White" />
                            </Border>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Right-side header actions (visible only while the drawer is open). -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0,0,10,0"
                                Visibility="{Binding LogConsole.IsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Content="Copy All"
                                Click="CopyAllLogsButton_OnClick"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="8,0"
                                Height="28"
                                FontSize="11"
                                ToolTip="Copy all visible log entries to the clipboard" />
                        <Button Content="Clear"
                                Command="{Binding LogConsole.ClearEntriesCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="8,0"
                                Height="28"
                                FontSize="11"
                                ToolTip="Remove all current log entries" />
                    </StackPanel>
                </Grid>

                <!-- Drawer body (only rendered when IsOpen). -->
                <Grid Grid.Row="1"
                      Height="180"
                      Visibility="{Binding LogConsole.IsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <!--
                        Virtualization + recycling keeps the log list fast even when
                        bursts of entries arrive. Pixel-based scrolling stays smooth.
                    -->
                    <ListView x:Name="LogConsoleListView"
                              ItemsSource="{Binding LogConsole.Entries}"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="10,0,10,10"
                              FontFamily="Consolas"
                              FontSize="12"
                              SelectionMode="Extended"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              ScrollViewer.CanContentScroll="True"
                              PreviewKeyDown="LogConsoleListView_OnPreviewKeyDown"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ContextMenu>
                            <ContextMenu Opened="LogConsoleContextMenu_OnOpened">
                                <MenuItem x:Name="CopySelectedLogMenuItem"
                                          Header="Copy Selected"
                                          Click="CopySelectedLogMenuItem_OnClick" />
                                <MenuItem x:Name="CopyAllLogsMenuItem"
                                          Header="Copy All"
                                          Click="CopyAllLogsMenuItem_OnClick" />
                                <Separator />
                                <MenuItem x:Name="ClearLogsMenuItem"
                                          Header="Clear Logs"
                                          Click="ClearLogsMenuItem_OnClick" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{DynamicResource ZenMutedTextBrush}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>
