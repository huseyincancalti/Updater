<Window x:Class="ZenUpdate.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ZenUpdate.App.ViewModels"
        xmlns:views="clr-namespace:ZenUpdate.App.Views"
        Title="ZenUpdate"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="800"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource AppBackgroundBrush}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">

    <!--
        DataContext is set in App.xaml.cs to ShellViewModel.
        No code-behind logic here.
    -->

    <!-- DataTemplates: map page ViewModels to their Views -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProgramsViewModel}">
            <views:ProgramsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WindowsUpdatesViewModel}">
            <views:WindowsUpdatesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DriversViewModel}">
            <views:DriversView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Main content area -->
            <RowDefinition Height="*" />
            <!-- Log console panel -->
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <!-- ===== Main Area: Sidebar + Content ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== Left Sidebar Navigation ===== -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource MaterialDesignDivider}">
                <StackPanel>

                    <!-- App logo / title -->
                    <TextBlock Text="ZenUpdate"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               Margin="20,24,20,24" />

                    <Separator Margin="8,0" />

                    <!-- Navigation buttons -->
                    <!-- Navigation: Buttons support Command binding; ListBoxItem does not -->                    
                    <StackPanel>

                        <Button x:Name="NavPrograms"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="20,12"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="{x:Static vm:AppPage.Programs}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PackageVariant" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Programs" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavWindowsUpdates"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="20,12"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="{x:Static vm:AppPage.WindowsUpdates}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MicrosoftWindows" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Windows Updates" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavDrivers"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="20,12"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="{x:Static vm:AppPage.Drivers}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cpu64Bit" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Drivers" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavSettings"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="20,12"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="{x:Static vm:AppPage.Settings}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cog" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Right Content Area ===== -->
            <!-- ContentControl automatically uses the DataTemplate matching CurrentPage's type -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentPage}"
                            Margin="0" />
        </Grid>

        <!-- ===== Bottom Log Console Panel ===== -->
        <Border Grid.Row="1"
                Background="#FF0D0D1A"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="LOG CONSOLE"
                           FontSize="10"
                           FontWeight="Bold"
                           Opacity="0.5"
                           Margin="12,6,0,4" />

                <ListView Grid.Row="1"
                          ItemsSource="{Binding LogConsole.Entries}"
                          Background="Transparent"
                          BorderThickness="0"
                          Margin="8,0,8,8"
                          FontFamily="Consolas"
                          FontSize="12"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#FFAAAAAA" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

    </Grid>
</Window>
