<UserControl x:Class="ZenUpdate.App.Views.ProgramsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        DataContext is set automatically by MainWindow's DataTemplate binding.
        DataContext type: ProgramsViewModel
    -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Programs"
                   Style="{StaticResource PageTitleStyle}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">

            <Button Content="Scan for Updates"
                    Command="{Binding ScanCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Padding="14,8"
                    Margin="0,0,8,0" />

            <Button Content="Update Selected"
                    Command="{Binding InstallSelectedCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Padding="14,8"
                    Margin="0,0,8,0" />

            <Button Content="Cancel"
                    Command="{Binding CancelScanCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <!--
                Scan-only thin progress bar.
                Bound to IsScanning so it stays hidden while installs/updates run;
                install/update progress is shown by the dedicated feedback panel below.
            -->
            <ProgressBar IsIndeterminate="True"
                         Width="110"
                         Height="4"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />

        </StackPanel>

        <Border Grid.Row="2"
                Style="{StaticResource ZenGlassPanelStyle}"
                Margin="0,0,0,14"
                Padding="14"
                Visibility="{Binding IsUpdateBatchRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding CurrentBatchProgressText}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />

                <TextBlock Grid.Row="1"
                           Text="{Binding OverallProgressPercent, StringFormat=Overall progress: {0}%}"
                           Opacity="0.78"
                           FontSize="12"
                           Margin="0,0,0,6" />

                <ProgressBar Grid.Row="2"
                             Height="7"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding OverallProgressPercent}"
                             Margin="0,0,0,10" />

                <TextBlock Grid.Row="3"
                           Text="{Binding CurrentAppName, StringFormat=Current app: {0}}"
                           Margin="0,0,0,4" />

                <TextBlock Grid.Row="4"
                           Text="{Binding CurrentInstallDetailText}"
                           Opacity="0.7"
                           FontSize="12"
                           Margin="0,0,0,6" />

                <StackPanel Grid.Row="5">
                    <TextBlock Text="{Binding CurrentItemProgressText}"
                               Opacity="0.78"
                               FontSize="12"
                               Margin="0,0,0,6" />
                    <ProgressBar Height="6"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding CurrentItemProgressPercent}"
                                 IsIndeterminate="{Binding IsCurrentItemProgressIndeterminate}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <!--
                Virtualization flags keep scrolling smooth for large result sets:
                  - IsVirtualizing + Recycling: only visible rows are realized, containers reused.
                  - ScrollUnit="Pixel": smooth pixel scroll instead of row-jump.
                  - EnableRowVirtualization/EnableColumnVirtualization: DataGrid-specific toggles.
                DataGrid body stays solid (MaterialDesignPaper) for row readability; only the
                outer chrome uses the glass-tinted frame.
            -->
            <Border Style="{StaticResource ZenDataGridChromeStyle}"
                    Visibility="{Binding HasUpdates, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DataGrid x:Name="ProgramsDataGrid"
                      ItemsSource="{Binding Updates}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      ClipboardCopyMode="ExcludeHeader"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      ScrollViewer.CanContentScroll="True"
                      Background="{DynamicResource MaterialDesignPaper}"
                      PreviewMouseRightButtonDown="ProgramsDataGrid_OnPreviewMouseRightButtonDown"
                      materialDesign:DataGridAssist.CellPadding="8 6"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8 6">
                <DataGrid.ContextMenu>
                    <ContextMenu Opened="ProgramsContextMenu_OnOpened">
                        <MenuItem x:Name="CopyPackageIdMenuItem"
                                  Header="Copy Package ID"
                                  Click="CopyPackageIdMenuItem_OnClick" />
                        <MenuItem x:Name="CopyAppNameMenuItem"
                                  Header="Copy App Name"
                                  Click="CopyAppNameMenuItem_OnClick" />
                        <MenuItem x:Name="CopyAppNameAndPackageIdMenuItem"
                                  Header="Copy App Name + Package ID"
                                  Click="CopyAppNameAndPackageIdMenuItem_OnClick" />
                        <MenuItem x:Name="CopySelectedPackageIdsMenuItem"
                                  Header="Copy Selected Package IDs"
                                  Click="CopySelectedPackageIdsMenuItem_OnClick" />
                        <Separator />
                        <MenuItem x:Name="AddToBlacklistMenuItem"
                                  Header="Add to Blacklist"
                                  Click="AddToBlacklistMenuItem_OnClick" />
                        <MenuItem x:Name="AddSelectedToBlacklistMenuItem"
                                  Header="Add Selected to Blacklist"
                                  Click="AddSelectedToBlacklistMenuItem_OnClick" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>

                    <DataGridCheckBoxColumn Header=""
                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="40" />

                <!--
                    Template column gives us text trimming and a full-name tooltip.
                    Width="*" expands to fill all remaining space left by the fixed columns.
                -->
                    <DataGridTemplateColumn Header="Application"
                                            Width="*"
                                            IsReadOnly="True"
                                            SortMemberPath="DisplayName">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           ToolTip="{Binding DisplayName}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Package ID"
                                            Width="220"
                                            IsReadOnly="True"
                                            SortMemberPath="WingetPackageId">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WingetPackageId}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           ToolTip="{Binding WingetPackageId}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Publisher"
                                            Width="170"
                                            IsReadOnly="True"
                                            SortMemberPath="Publisher">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Publisher}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           ToolTip="{Binding Publisher}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Current Ver."
                                        Binding="{Binding CurrentVersion}"
                                        Width="110"
                                        IsReadOnly="True" />

                    <DataGridTextColumn Header="New Ver."
                                        Binding="{Binding AvailableVersion}"
                                        Width="110"
                                        IsReadOnly="True" />

                    <DataGridTemplateColumn Header="Status"
                                            Width="110"
                                            IsReadOnly="True"
                                            SortMemberPath="Status"
                                            CellTemplate="{StaticResource StatusBadgeCellTemplate}" />

                </DataGrid.Columns>
            </DataGrid>
            </Border>

            <Border Style="{StaticResource ZenGlassPanelStyle}"
                    Padding="24"
                    Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="No application updates found. All clear for now."
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Your installed programs are already up to date, so there is nothing to install right now."
                               Opacity="0.7"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Opacity="0.65"
                   FontSize="12"
                   Margin="0,8,0,0" />

    </Grid>
</UserControl>
