<UserControl x:Class="ZenUpdate.App.Views.ProgramsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        DataContext is set automatically by MainWindow's DataTemplate binding.
        DataContext type: ProgramsViewModel
    -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Programs"
                   Style="{StaticResource PageTitleStyle}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">

            <Button Content="Scan for Updates"
                    Command="{Binding ScanCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,0,8,0" />

            <Button Content="Cancel"
                    Command="{Binding CancelScanCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Button Content="Update Selected"
                    Command="{Binding InstallSelectedCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" />

            <ProgressBar IsIndeterminate="True"
                         Width="120"
                         Height="4"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Padding="12"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding IsUpdateBatchRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding CurrentBatchProgressText}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding CurrentAppName, StringFormat=Current app: {0}}"
                           Margin="0,0,0,6" />
                <ProgressBar IsIndeterminate="True"
                             Height="6"
                             Margin="0,0,0,6" />
                <TextBlock Text="{Binding CurrentInstallDetailText}"
                           Opacity="0.7"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3"
                  x:Name="ProgramsDataGrid"
                  ItemsSource="{Binding Updates}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  PreviewMouseRightButtonDown="ProgramsDataGrid_OnPreviewMouseRightButtonDown"
                  materialDesign:DataGridAssist.CellPadding="8 6"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8 6">
            <DataGrid.ContextMenu>
                <ContextMenu Opened="ProgramsContextMenu_OnOpened">
                    <MenuItem x:Name="CopyPackageIdMenuItem"
                              Header="Copy Package ID"
                              Click="CopyPackageIdMenuItem_OnClick" />
                    <MenuItem x:Name="CopyAppNameMenuItem"
                              Header="Copy App Name"
                              Click="CopyAppNameMenuItem_OnClick" />
                    <MenuItem x:Name="CopyAppNameAndPackageIdMenuItem"
                              Header="Copy App Name + Package ID"
                              Click="CopyAppNameAndPackageIdMenuItem_OnClick" />
                    <MenuItem x:Name="CopySelectedPackageIdsMenuItem"
                              Header="Copy Selected Package IDs"
                              Click="CopySelectedPackageIdsMenuItem_OnClick" />
                    <Separator />
                    <MenuItem x:Name="AddToBlacklistMenuItem"
                              Header="Add to Blacklist"
                              Click="AddToBlacklistMenuItem_OnClick" />
                    <MenuItem x:Name="AddSelectedToBlacklistMenuItem"
                              Header="Add Selected to Blacklist"
                              Click="AddSelectedToBlacklistMenuItem_OnClick" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>

                <DataGridCheckBoxColumn Header=""
                                        Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        Width="40" />

                <DataGridTextColumn Header="Application"
                                    Binding="{Binding DisplayName}"
                                    Width="*"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="Package ID"
                                    Binding="{Binding WingetPackageId}"
                                    Width="220"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="Publisher"
                                    Binding="{Binding Publisher}"
                                    Width="160"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="Current Version"
                                    Binding="{Binding CurrentVersion}"
                                    Width="130"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="New Version"
                                    Binding="{Binding AvailableVersion}"
                                    Width="130"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="100"
                                    IsReadOnly="True" />

            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Opacity="0.65"
                   FontSize="12"
                   Margin="0,8,0,0" />

    </Grid>
</UserControl>
