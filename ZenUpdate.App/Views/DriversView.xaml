<UserControl x:Class="ZenUpdate.App.Views.DriversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Drivers" Style="{StaticResource PageTitleStyle}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Scan for Driver Updates"
                    Command="{Binding ScanCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,0,8,0" />

            <Button Content="Install Selected"
                    Command="{Binding InstallSelectedCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" />

            <Button Content="Cancel"
                    Command="{Binding CancelScanCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <!--
                Scan-only thin progress bar.
                Bound to IsScanning so it stays hidden while installs run;
                install progress is shown by the dedicated feedback panel below.
            -->
            <ProgressBar IsIndeterminate="True"
                         Width="120"
                         Height="4"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Padding="12"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding IsInstallBatchRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding CurrentBatchProgressText}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding CurrentDriverTitle, StringFormat=Current driver: {0}}"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding CurrentDriverContextText}"
                           Margin="0,0,0,6"
                           Visibility="{Binding HasCurrentDriverContextText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ProgressBar IsIndeterminate="True"
                             Height="6"
                             Margin="0,0,0,6" />
                <TextBlock Text="{Binding CurrentInstallDetailText}"
                           Opacity="0.7"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <DataGrid x:Name="DriversDataGrid"
                      ItemsSource="{Binding Updates}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      ClipboardCopyMode="ExcludeHeader"
                      Visibility="{Binding HasUpdates, Converter={StaticResource BooleanToVisibilityConverter}}"
                      PreviewMouseRightButtonDown="DriversDataGrid_OnPreviewMouseRightButtonDown"
                      materialDesign:DataGridAssist.CellPadding="8 6"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8 6">
                <DataGrid.ContextMenu>
                    <ContextMenu Opened="DriversContextMenu_OnOpened">
                        <MenuItem x:Name="CopyDriverTitleMenuItem"
                                  Header="Copy Driver Title"
                                  Click="CopyDriverTitleMenuItem_OnClick" />
                        <MenuItem x:Name="CopyDriverManufacturerMenuItem"
                                  Header="Copy Manufacturer"
                                  Click="CopyDriverManufacturerMenuItem_OnClick" />
                        <MenuItem x:Name="CopyDriverTitleAndManufacturerMenuItem"
                                  Header="Copy Driver Title + Manufacturer"
                                  Click="CopyDriverTitleAndManufacturerMenuItem_OnClick" />
                        <MenuItem x:Name="CopySelectedDriverTitlesMenuItem"
                                  Header="Copy Selected Titles"
                                  Click="CopySelectedDriverTitlesMenuItem_OnClick" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header=""
                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="40"
                                            IsReadOnly="False" />

                    <DataGridTemplateColumn Header="Driver / Device"
                                            Width="*"
                                            IsReadOnly="True"
                                            SortMemberPath="DisplayName">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           ToolTip="{Binding DisplayName}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Manufacturer"
                                            Width="190"
                                            IsReadOnly="True"
                                            SortMemberPath="Manufacturer">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Manufacturer}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           ToolTip="{Binding Manufacturer}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Device Class"
                                            Width="150"
                                            IsReadOnly="True"
                                            SortMemberPath="DeviceClass">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DeviceClass}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           ToolTip="{Binding DeviceClass}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="100"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Padding="24"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    Background="{DynamicResource MaterialDesignPaper}"
                    Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="No driver updates found. Your devices look current for now."
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Windows Update did not report any pending driver updates on this scan."
                               Opacity="0.7"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Opacity="0.6"
                   Margin="0,8,0,0"
                   FontSize="12" />
    </Grid>
</UserControl>
