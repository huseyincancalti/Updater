<UserControl x:Class="ZenUpdate.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:enums="clr-namespace:ZenUpdate.Core.Enums;assembly=ZenUpdate.Core">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="700" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />

            <!-- General Settings Card -->
            <materialDesign:Card Style="{StaticResource ZenGlassCardStyle}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="General"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12" />

                    <CheckBox Content="Scan for updates on startup"
                              IsChecked="{Binding Settings.ScanOnStartup}"
                              Margin="0,0,0,12" />

                    <CheckBox Content="Minimize to system tray on close"
                              IsChecked="{Binding Settings.MinimizeToTray}"
                              Margin="0,0,0,24" />

                    <!-- Theme selection area -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Appearance"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Opacity="0.8"
                                   Margin="0,0,0,8" />
                        <ComboBox Width="200"
                                  HorizontalAlignment="Left"
                                  SelectedItem="{Binding Settings.Theme}">
                            <x:Static Member="enums:AppTheme.Dark" />
                            <x:Static Member="enums:AppTheme.Light" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Save Settings"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,0,8,0" />

                        <Button Content="Reload"
                                Command="{Binding LoadCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Blacklist Card -->
            <materialDesign:Card Style="{StaticResource ZenGlassCardStyle}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Blacklist"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Apps in this list will be excluded from winget update results."
                               Opacity="0.6"
                               FontSize="12"
                               Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding NewBlacklistPackageId, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Package ID"
                                 Margin="0,0,8,0" />

                        <TextBox Grid.Column="1"
                                 Text="{Binding NewBlacklistReason, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Reason (optional)"
                                 Margin="0,0,8,0" />

                        <Button Grid.Column="2"
                                Content="Add"
                                Command="{Binding AddBlacklistEntryCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                    </Grid>

                    <!--
                        SelectionMode="Extended" lets the user Ctrl/Shift-click to select
                        multiple rows. SelectedItem still two-way-binds for the single-row
                        command guard (RemoveSelectedBlacklistEntryCommand.CanExecute).
                        The x:Name is needed by the code-behind handlers.
                    -->
                    <DataGrid x:Name="BlacklistDataGrid"
                              ItemsSource="{Binding BlacklistEntries}"
                              SelectedItem="{Binding SelectedBlacklistEntry}"
                              SelectionMode="Extended"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              MinHeight="140"
                              materialDesign:DataGridAssist.CellPadding="8 6"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="8 6">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy Package ID"
                                          Click="CopyPackageIdMenuItem_OnClick" />
                                <MenuItem Header="Copy Selected Package IDs"
                                          Click="CopySelectedPackageIdsMenuItem_OnClick" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Package ID"
                                                Binding="{Binding PackageId}"
                                                Width="2*" />
                            <DataGridTextColumn Header="Reason"
                                                Binding="{Binding Reason}"
                                                Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!--
                        Click is handled in code-behind so it can read DataGrid.SelectedItems
                        (which contains all multi-selected rows) and call RemoveEntriesAsync.
                        The handler returns silently when no rows are selected.
                    -->
                    <Button Content="Remove Selected"
                            Click="RemoveSelectedButton_OnClick"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </materialDesign:Card>

            <TextBlock Text="{Binding StatusMessage}"
                       Opacity="0.65"
                       FontSize="12"
                       Margin="0,12,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
