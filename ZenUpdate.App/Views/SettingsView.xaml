<UserControl x:Class="ZenUpdate.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="700" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />

            <!-- General Settings Card -->
            <materialDesign:Card Style="{StaticResource ZenGlassCardStyle}" Padding="28" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="General"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,16" />

                    <CheckBox Content="Scan for updates on startup"
                              IsChecked="{Binding Settings.ScanOnStartup}"
                              Margin="0,0,0,12" />

                    <CheckBox Content="Minimize to system tray on close"
                              IsChecked="{Binding Settings.MinimizeToTray}"
                              Margin="0,0,0,24" />

                    <!-- Theme toggle: one click switches Dark ↔ Light; saves automatically -->
                    <Border Margin="0,0,0,24"
                            Padding="14,10"
                            CornerRadius="8"
                            Background="{DynamicResource ZenGlassPanelBrush}"
                            BorderBrush="{DynamicResource ZenGlassBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: label + subtitle -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Appearance"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="ThemeSubtitle"
                                           FontSize="11"
                                           Opacity="0.55"
                                           Margin="0,2,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <!-- Default: Dark mode is active -->
                                            <Setter Property="Text" Value="Currently: Dark" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLightTheme}" Value="True">
                                                    <Setter Property="Text" Value="Currently: Light" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!--
                                Pill toggle button.
                                Shows the NEXT action (what will happen on click):
                                  Dark active  → "Switch to Light" + sun icon
                                  Light active → "Switch to Dark"  + moon icon
                                Two separate StackPanels swap Visibility via DataTrigger on
                                IsLightTheme so the icon Kind is hardcoded (no binding needed
                                for the PackIcon Kind property — avoids DataContext loss issues).
                            -->
                            <Button Grid.Column="2"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource ZenThemeToggleStyle}"
                                    Command="{Binding ToggleThemeCommand}"
                                    ToolTip="Click to switch theme">
                                <Grid>
                                    <!-- Shown when Dark is active: clicking will go to Light -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLightTheme}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <materialDesign:PackIcon Kind="WeatherSunny"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0" />
                                        <TextBlock Text="Switch to Light" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Shown when Light is active: clicking will go to Dark -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLightTheme}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <materialDesign:PackIcon Kind="WeatherNight"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0" />
                                        <TextBlock Text="Switch to Dark" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Save Settings"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,0,8,0" />

                        <Button Content="Reload"
                                Command="{Binding LoadCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Blacklist Card -->
            <materialDesign:Card Style="{StaticResource ZenGlassCardStyle}" Padding="24" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Blacklist"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Apps in this list will be excluded from winget update results."
                               Opacity="0.6"
                               FontSize="12"
                               Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding NewBlacklistPackageId, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Package ID"
                                 Margin="0,0,8,0" />

                        <TextBox Grid.Column="1"
                                 Text="{Binding NewBlacklistReason, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Reason (optional)"
                                 Margin="0,0,8,0" />

                        <Button Grid.Column="2"
                                Content="Add"
                                Command="{Binding AddBlacklistEntryCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                    </Grid>

                    <!--
                        SelectionMode="Extended" lets the user Ctrl/Shift-click to select
                        multiple rows. SelectedItem still two-way-binds for the single-row
                        command guard (RemoveSelectedBlacklistEntryCommand.CanExecute).
                        The x:Name is needed by the code-behind handlers.
                    -->
                    <DataGrid x:Name="BlacklistDataGrid"
                              ItemsSource="{Binding BlacklistEntries}"
                              SelectedItem="{Binding SelectedBlacklistEntry}"
                              SelectionMode="Extended"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              MinHeight="140"
                              materialDesign:DataGridAssist.CellPadding="8 6"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="8 6">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy Package ID"
                                          Click="CopyPackageIdMenuItem_OnClick" />
                                <MenuItem Header="Copy Selected Package IDs"
                                          Click="CopySelectedPackageIdsMenuItem_OnClick" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Package ID"
                                                Binding="{Binding PackageId}"
                                                Width="2*" />
                            <DataGridTextColumn Header="Reason"
                                                Binding="{Binding Reason}"
                                                Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!--
                        Click is handled in code-behind so it can read DataGrid.SelectedItems
                        (which contains all multi-selected rows) and call RemoveEntriesAsync.
                        The handler returns silently when no rows are selected.
                    -->
                    <Button Content="Remove Selected"
                            Click="RemoveSelectedButton_OnClick"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </materialDesign:Card>

            <TextBlock Text="{Binding StatusMessage}"
                       Opacity="0.65"
                       FontSize="12"
                       Margin="0,12,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
