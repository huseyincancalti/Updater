<UserControl x:Class="ZenUpdate.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />

            <!-- General Settings Card -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="General"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12" />

                    <CheckBox Content="Scan for updates on startup"
                              IsChecked="{Binding Settings.ScanOnStartup}"
                              Margin="0,0,0,8" />

                    <CheckBox Content="Minimize to system tray on close"
                              IsChecked="{Binding Settings.MinimizeToTray}" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Blacklist Card -->
            <materialDesign:Card Padding="20">
                <StackPanel>
                    <TextBlock Text="Blacklist"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Apps in this list will be excluded from winget update results."
                               Opacity="0.6"
                               FontSize="12"
                               Margin="0,0,0,12" />

                    <!-- Blacklist table placeholder -->
                    <ListBox ItemsSource="{Binding BlacklistedIds}"
                             Background="Transparent"
                             BorderThickness="0"
                             MinHeight="80">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="13" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- TODO: Add text input + Add/Remove buttons -->
                    <TextBlock Text="Add/Remove blacklist entries — coming soon."
                               Opacity="0.4"
                               FontSize="11"
                               Margin="0,8,0,0" />
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
